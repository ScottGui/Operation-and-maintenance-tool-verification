#!/bin/bash

# 一键启动脚本 - 优化版（自动清理端口占用）
# 使用方法：./start [frontend|backend|all]
#   ./start         - 启动前端（默认）
#   ./start backend - 只启动后端
#   ./start all     - 同时启动前后端

set -e  # 遇到错误立即退出

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 项目根目录
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"

# PID文件目录
PID_DIR="/tmp/dmp_pids"
mkdir -p "$PID_DIR"

# 打印带颜色的信息
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 检查端口是否被占用
check_port() {
    local port=$1
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        return 0  # 端口被占用
    else
        return 1  # 端口可用
    fi
}

# 获取占用端口的进程PID
get_port_pid() {
    local port=$1
    lsof -Pi :$port -sTCP:LISTEN -t 2>/dev/null || echo ""
}

# 强制杀死进程树
kill_process_tree() {
    local pid=$1
    if [ -n "$pid" ] && [ "$pid" -gt 0 ] 2>/dev/null; then
        # 先杀死子进程
        local children=$(pgrep -P $pid 2>/dev/null || true)
        for child in $children; do
            kill_process_tree $child 2>/dev/null || true
        done
        # 再杀死自己
        kill -9 $pid 2>/dev/null || true
    fi
}

# 清理vite相关进程
cleanup_vite_processes() {
    print_info "清理已存在的 Vite 进程..."
    
    # 通过进程名查找并杀掉vite进程
    local vite_pids=$(pgrep -f "vite" 2>/dev/null || true)
    if [ -n "$vite_pids" ]; then
        for pid in $vite_pids; do
            # 只杀掉当前项目的vite进程
            if ps -p $pid -o command= 2>/dev/null | grep -q "$PROJECT_ROOT"; then
                kill_process_tree $pid
            fi
        done
    fi
    
    # 杀掉所有node进程中与vite相关的
    pkill -f "node.*vite" 2>/dev/null || true
    
    # 等待一下确保进程退出
    sleep 1
}

# 清理后端进程
cleanup_backend_processes() {
    print_info "清理已存在的后端进程..."
    
    # 杀掉uvicorn进程
    local uvicorn_pids=$(pgrep -f "uvicorn backend.src.main" 2>/dev/null || true)
    if [ -n "$uvicorn_pids" ]; then
        for pid in $uvicorn_pids; do
            kill_process_tree $pid
        done
    fi
    
    # 等待一下确保进程退出
    sleep 1
}

# 强制清理端口
force_cleanup_port() {
    local port=$1
    local port_pids=$(get_port_pid $port)
    
    if [ -n "$port_pids" ]; then
        print_warning "端口 $port 被占用，正在强制清理..."
        for pid in $port_pids; do
            kill_process_tree $pid
        done
        sleep 1
        
        # 再次检查
        if check_port $port; then
            return 1  # 清理失败
        fi
    fi
    return 0
}

# 检查命令是否存在
check_command() {
    if ! command -v "$1" &> /dev/null; then
        print_error "$1 未安装，请先安装"
        exit 1
    fi
}

# 检查环境
check_environment() {
    print_info "检查开发环境..."
    
    # 检查Node.js
    if command -v node &> /dev/null; then
        NODE_VERSION=$(node --version)
        print_success "Node.js 已安装: $NODE_VERSION"
    else
        print_error "Node.js 未安装，请先安装 Node.js 18+"
        exit 1
    fi
    
    # 检查Python
    if command -v python3 &> /dev/null; then
        PYTHON_VERSION=$(python3 --version)
        print_success "Python 已安装: $PYTHON_VERSION"
    else
        print_error "Python3 未安装，请先安装 Python 3.9+"
        exit 1
    fi
    
    # 检查前端依赖
    if [ ! -d "$PROJECT_ROOT/frontend/node_modules" ]; then
        print_warning "前端依赖未安装，正在安装..."
        cd "$PROJECT_ROOT/frontend"
        npm install
        print_success "前端依赖安装完成"
    fi
    
    # 检查后端的依赖（简单检查）
    if ! python3 -c "import fastapi" 2>/dev/null; then
        print_warning "后端依赖未安装，正在安装..."
        cd "$PROJECT_ROOT/backend"
        pip3 install -r requirements.txt
        print_success "后端依赖安装完成"
    fi
    
    print_success "环境检查通过！"
    echo ""
}

# 启动后端服务
start_backend() {
    print_info "启动后端服务..."
    
    # 先清理已有后端进程
    cleanup_backend_processes
    
    # 检查并清理端口
    if check_port 8000; then
        if ! force_cleanup_port 8000; then
            print_error "无法释放端口 8000，请手动检查"
            exit 1
        fi
    fi
    
    cd "$PROJECT_ROOT"
    
    # 设置Python路径并启动后端
    export PYTHONPATH="$PROJECT_ROOT"
    
    # 先创建数据库表（如果不存在）
    python3 -c "from backend.src.models import create_tables; create_tables()" 2>/dev/null || true
    
    # 后台启动后端服务
    nohup python3 -m uvicorn backend.src.main:app \
        --host 0.0.0.0 \
        --port 8000 \
        --reload \
        > /tmp/backend.log 2>&1 &
    
    local backend_pid=$!
    echo $backend_pid > "$PID_DIR/backend.pid"
    
    # 等待后端启动
    print_info "等待后端服务启动..."
    for i in {1..15}; do
        if curl -s http://localhost:8000/api/health >/dev/null 2>&1; then
            print_success "后端服务启动成功！"
            print_info "后端地址: http://localhost:8000"
            print_info "API文档: http://localhost:8000/docs"
            return 0
        fi
        sleep 1
    done
    
    print_error "后端服务启动失败，请检查日志: /tmp/backend.log"
    exit 1
}

# 启动前端服务
start_frontend() {
    print_info "启动前端服务..."
    
    # 先清理已有vite进程
    cleanup_vite_processes
    
    # 检查并清理端口
    for port in 5173 5174 5175 5176 5177; do
        if check_port $port; then
            print_warning "端口 $port 被占用，尝试清理..."
            if ! force_cleanup_port $port; then
                print_warning "无法清理端口 $port，尝试下一个端口..."
                continue
            fi
        fi
        break
    done
    
    cd "$PROJECT_ROOT/frontend"
    
    print_info "前端地址: http://localhost:5173 (或自动分配的端口)"
    print_info "正在启动，请稍候..."
    echo ""
    
    # 启动前端（前台运行，方便查看日志）
    npm run dev
}

# 停止所有服务
stop_all() {
    print_info "停止所有服务..."
    
    # 停止后端
    cleanup_backend_processes
    rm -f "$PID_DIR/backend.pid"
    
    # 停止前端
    cleanup_vite_processes
    rm -f "$PID_DIR/frontend.pid"
    
    # 清理PID目录
    rm -rf "$PID_DIR"
    
    print_success "所有服务已停止"
}

# 显示帮助信息
show_help() {
    echo "公共数据服务全生命周期管理平台 - 一键启动脚本（优化版）"
    echo ""
    echo "使用方法:"
    echo "  ./start           - 只启动前端（默认）"
    echo "  ./start frontend  - 只启动前端"
    echo "  ./start backend   - 只启动后端（后台运行）"
    echo "  ./start all       - 同时启动前后端"
    echo "  ./start stop      - 停止所有服务"
    echo ""
    echo "访问地址:"
    echo "  前端: http://localhost:5173"
    echo "  后端: http://localhost:8000"
    echo "  API文档: http://localhost:8000/docs"
    echo ""
    echo "特性:"
    echo "  ✓ 自动清理已存在的进程"
    echo "  ✓ 自动检测和释放端口"
    echo "  ✓ Ctrl+C 安全退出"
    echo ""
}

# 主逻辑
main() {
    # 如果没有参数，默认启动前端
    if [ $# -eq 0 ]; then
        MODE="frontend"
    else
        MODE="$1"
    fi
    
    case "$MODE" in
        "frontend"|"f"|"front")
            check_environment
            start_frontend
            ;;
        "backend"|"b"|"back")
            check_environment
            start_backend
            print_success "后端服务已在后台运行"
            print_info "查看日志: tail -f /tmp/backend.log"
            print_info "停止服务: ./start stop"
            ;;
        "all"|"a")
            check_environment
            start_backend
            echo ""
            start_frontend
            ;;
        "stop"|"s"|"down")
            stop_all
            ;;
        "cleanup"|"clean")
            print_info "仅执行清理操作..."
            cleanup_vite_processes
            cleanup_backend_processes
            rm -rf "$PID_DIR"
            print_success "清理完成"
            ;;
        "help"|"h"|"-h"|"--help")
            show_help
            ;;
        *)
            print_error "未知参数: $MODE"
            show_help
            exit 1
            ;;
    esac
}

# 捕获Ctrl+C信号
trap 'echo ""; print_warning "收到中断信号"; stop_all; exit 0' INT

# 执行主逻辑
main "$@"
